{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/discovery",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/enrichment",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/briefs",
      "schedule": "2,12,22,32,42,52 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "*/15 * * * *"
    }
  ]
}
