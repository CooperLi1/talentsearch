# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Private dashboard gate. Both are required in production; SESSION_SECRET must
# be at least 32 random characters. Never prefix either value with NEXT_PUBLIC_.
DASHBOARD_PASSWORD=
SESSION_SECRET=

# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` to scheduled routes.
# Use a separate random value; do not reuse the dashboard or session secret.
CRON_SECRET=

# Supabase. The publishable key may be used in browser code protected by RLS.
# The service-role key bypasses RLS and must remain server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional numeric workspace selected by server-side no-argument reads.
UNFOUND_WORKSPACE_ID=

# LLM summaries, query parsing, and embeddings. Vercel deployments may provide
# VERCEL_OIDC_TOKEN automatically instead of a long-lived AI_GATEWAY_API_KEY.
AI_GATEWAY_API_KEY=
AI_MODEL=openai/gpt-4o-mini
AI_SUMMARY_MODEL=openai/gpt-4o-mini
AI_QUERY_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Weekly email. Delivery is disabled unless explicitly set to `send`.
EMAIL_DELIVERY_MODE=preview
RESEND_API_KEY=
RESEND_FROM="Unfound <digest@example.com>"
RESEND_REPLY_TO=
# Optional one-time subscriber used by `npm run setup:operator` after migrations.
INITIAL_DIGEST_SUBSCRIBER_EMAIL=

# Authenticated/attributed source APIs
GITHUB_TOKEN=
GITLAB_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=
# Optional read-only Hub token. Public discovery also works anonymously.
HF_TOKEN=
# Required for every OpenAlex request. Keep server-only.
OPENALEX_API_KEY=
# Legacy attribution only; OpenAlex has ignored mailto since February 2026.
OPENALEX_EMAIL=
CROSSREF_EMAIL=
X_BEARER_TOKEN=
# Keep false until X has approved this disclosed cross-platform research use
# and the required retention/deletion controls are operational.
X_DATA_USE_APPROVED=false
BRAVE_SEARCH_API_KEY=
# Search responses are locator-only by default. The current connector never
# stores Brave snippets or response bodies, even when this remains false.
BRAVE_SEARCH_STORAGE_ALLOWED=false

# LinkedIn pages are never scraped. Enable these only for a separately approved
# server-side profile lookup integration that implements docs/connectors.md.
LINKEDIN_DIRECT_ACCESS_APPROVED=false
LINKEDIN_APPROVED_API_BASE_URL=
LINKEDIN_APPROVED_API_TOKEN=

# Service actor UUID used to attribute feedback writes.
UNFOUND_ACTOR_USER_ID=

# Optional hard cost caps for scheduled intelligence refreshes.
AI_EVENT_SUMMARY_LIMIT=8
# Deterministic scoring can drain a larger queue. A separate durable worker
# generates source-linked briefs for resolved candidates with substantive public
# evidence, in bounded batches that use the configured summary model.
AUTOMATIC_REVIEW_LIMIT=100
CANDIDATE_BRIEF_BATCH_LIMIT=30
# Per-run public-page enrichment budget. A rotating worker runs three times per
# hour; keep each invocation bounded so a slow publisher cannot strand the batch.
DISCOVERY_ENRICHMENT_LIMIT=3
# Optional separate HMAC secret for rate-limit identifiers. SESSION_SECRET is
# used when this is empty; raw client addresses are never stored.
RATE_LIMIT_HASH_SECRET=
INTELLIGENCE_REFRESH_LIMIT=20

# Continuous background worker. These values are used by Render (render.yaml)
# and by `npm run worker:enrichment:local`; they never belong in browser code.
WORKER_ENRICHMENT_CONCURRENCY=2
WORKER_CONNECTORS_PER_PASS=8
WORKER_POLL_MS=5000
WORKER_EMPTY_POLL_MS=60000
# Keep below the database claim lease (currently six minutes).
WORKER_CANDIDATE_TIMEOUT_MS=240000
WORKER_ERROR_BACKOFF_MS=15000
WORKER_ENABLE_BRIEFS=true
WORKER_BRIEF_INTERVAL_MS=60000
WORKER_BRIEF_BATCH_LIMIT=6
# Set this only in Vercel after the external worker is healthy. It makes the
# legacy enrichment and brief cron routes return without claiming work.
EXTERNAL_WORKER_ACTIVE=false

# Optional JSON override for connector queries, feed URLs, result-page
# definitions, graph budgets, and per-source caps. Prefer dashboard settings.
DISCOVERY_CONNECTOR_CONFIG=
